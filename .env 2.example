# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (magic link redirect, webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama (local or public URL for deployed API routes)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# Community STT (в библиотеке Ollama нет короткого имени `whisper`):
OLLAMA_STT_MODEL=dimavz/whisper-tiny

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=
# Optional: same value as secret_token in setWebhook
TELEGRAM_WEBHOOK_SECRET=

# PostHog (Project → API keys)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
