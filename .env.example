# Скопируйте в .env и задайте свои значения (файл .env в git не коммитим).

POSTGRES_USER=habit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=habit

# FastAPI + Alembic (локально при `docker compose up db`)
DATABASE_URL=postgresql://habit:change_me@localhost:5432/habit

# Подппись JWT (≥32 символа). В Docker передайте как JWT_SECRET
JWT_SECRET=insecure_dev_only_set_JWT_SECRET_in_production_32char_min

# Прод: список origin для CORS (через запятую), если к API ходят с другого origin.
# Вариант «только Caddy+SPA с одного хоста» CORS к браузеру обычно не нужен.
# CORS_ORIGINS=https://ваш.домен,http://ваш-ip

# Ollama (локальная LLM для AI Coach)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Yandex Cloud / firewall: снаружи обычно 80, 443; SSH (22) — только с вашего IP
