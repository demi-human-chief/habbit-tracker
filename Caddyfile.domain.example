# Скопируйте в Caddyfile (или вставьте вместо блока :80) и задайте домен.
# Секция email опциональна, для настройки ACME.

{
	email you@example.com
}

habit.example.com {
	encode gzip

	@api {
		path /api* /docs* /redoc* /openapi.json /health*
	}
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:80
	}
}
